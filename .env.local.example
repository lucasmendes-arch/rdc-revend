# ============================================================================
# SUPABASE FRONTEND (Development - .env.local)
# ============================================================================
# ⚠️  DO NOT commit this file! It's in .gitignore for a reason.
# Get credentials from: https://app.supabase.com/project/[project-id]/settings/api

# Your Supabase project URL
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Your Supabase Anon (public) key
# This is safe to share - row-level security enforces permissions
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InlvdXItcHJvamVjdC1pZCIsInJvbGUiOiJhbm9uIiwiaWF0IjoxNzAwMDAwMDAwLCJleHAiOjIwMDAwMDAwMDB9.PLACEHOLDER_KEY_PASTE_YOUR_REAL_KEY_HERE

# Supabase Service Role key — usado apenas em scripts admin (nunca expor no frontend)
# Obter em: https://app.supabase.com/project/[project-id]/settings/api → service_role
SERVICE_ROLE_KEY=

# ============================================================================
# META PIXEL + CONVERSIONS API (Server-Side Tracking)
# ============================================================================
# Pixel ID usado pela Meta Conversion API no servidor.
VITE_REACT_APP_PIXEL_ID=SEU_PIXEL_ID

# Token gerado em Events Manager > Settings > Conversions API.
# Nunca commite o valor real.
FACEBOOK_ACCESS_TOKEN=SEU_TOKEN_DA_META_CONVERSIONS_API

# Opcional: útil para validar eventos no Test Events da Meta.
FACEBOOK_TEST_EVENT_CODE=SEU_TEST_EVENT_CODE

# Opcional: só use true se você realmente quiser disparar eventos reais fora do Test Events.

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================
# 1. Copy this file to .env.local (will be ignored by git):
#    cp .env.local.example .env.local
#
# 2. Get your Supabase credentials:
#    - Go to https://app.supabase.com/project/[project-id]/settings/api
#    - Copy "Project URL" → VITE_SUPABASE_URL
#    - Copy "Anon public key" → VITE_SUPABASE_ANON_KEY
#
# 3. DO NOT commit .env.local (it's in .gitignore)
#    If you accidentally do, revoke credentials in Supabase Dashboard
#
# 4. Backend secrets (UAZAPI_TOKEN) should be
#    configured in Supabase Dashboard → Settings → Edge Functions → Secrets
#    DO NOT put them in .env.local!
#
# ============================================================================
# SECURITY REMINDERS
# ============================================================================
# ⚠️  NEVER commit real credentials
# ⚠️  NEVER share .env.local in Slack, email, or GitHub
# ⚠️  NEVER hardcode secrets in source files
# ⚠️  If credentials are exposed, revoke them immediately in Supabase
